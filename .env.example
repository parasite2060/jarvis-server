# Jarvis Server - Environment Variables
# ================================================
# Copy to .env and fill in required values.

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=          # REQUIRED
POSTGRES_DB=jarvis

# Redis
REDIS_URL=redis://localhost:6379/0

# Azure OpenAI
AZURE_OPENAI_API_KEY=       # REQUIRED
AZURE_OPENAI_ENDPOINT=      # REQUIRED — e.g. https://your-resource.cognitiveservices.azure.com/

# Azure OpenAI (OpenAI-compatible endpoints, used by MemU via docker-compose)
AZURE_OPENAI_BASE_URL=      # REQUIRED — e.g. https://your-resource.cognitiveservices.azure.com/openai/v1/
AZURE_OPENAI_EMBEDDING_BASE_URL=  # REQUIRED — same as above, or separate embedding endpoint

# ai-memory repo path
AI_MEMORY_REPO_PATH=/tmp/ai-memory

# Server
JARVIS_API_KEY=             # REQUIRED
JARVIS_LOG_LEVEL=INFO

# MemU
MEMU_BASE_URL=http://localhost:8010
