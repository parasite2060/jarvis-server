# Jarvis Server — Environment Variables
# ================================================
# Copy to .env and fill in required values.

# ── Database ──
DB_HOST=localhost
DB_PORT=5432
DB_USER=jarvis
DB_PASSWORD=                          # REQUIRED
DB_NAME=jarvis

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── LLM (any OpenAI-compatible provider) ──
LLM_API_KEY=                          # REQUIRED
LLM_ENDPOINT=                         # REQUIRED — e.g. https://api.openai.com/
LLM_MODEL=                            # REQUIRED — e.g. gpt-4o
LLM_BASE_URL=                         # REQUIRED — e.g. https://api.openai.com/v1/
LLM_EMBEDDING_BASE_URL=               # REQUIRED — same or separate endpoint
LLM_EMBEDDING_MODEL=text-embedding-3-large

# ── Jarvis Server ──
JARVIS_API_KEY=                       # REQUIRED
JARVIS_LOG_LEVEL=INFO
JARVIS_MEMORY_PATH=/tmp/ai-memory
JARVIS_GITHUB_PAT=                    # REQUIRED for dream PR creation

# ── MemU ──
MEMU_BASE_URL=http://localhost:8010

# ── Temporal ──
TEMPORAL_ADDRESS=192.168.50.129:7233  # Temporal server host:port (gRPC)
TEMPORAL_NAMESPACE=jarvis             # Temporal namespace provisioned by Story 12.0
TEMPORAL_TASK_QUEUE=jarvis-dream      # Canonical task queue for all Epic-12 workflows
