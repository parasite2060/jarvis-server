# Server
HOST=0.0.0.0
PORT=3000
NODE_ENV=local                    # local | development | staging | production | test | provision
RUNTIME_ENV=local                 # local | dev | test | stage | prod
TZ=UTC

# CORS (only applies in non-production environments)
CORS_ORIGINS=*                    # comma-separated origins or * for all

# Logger
LOG_LEVEL=debug                   # trace | debug | info | warn | error | fatal
LOG_OUTPUT=text                   # text | json
LOG_FILE_PATH=                    # optional: path to log file
LOG_SYNC_FILE=/var/run/application.pid

# GRPC
GRPC_PORT=5000
GRPC_URL=0.0.0.0
MAX_SEND_SIZE_IN_MB=10
MAX_RECEIVE_SIZE_IN_MB=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# MongoDB
MONGODB_URI=mongodb://root:123456@localhost:27017/service-template-local-db?authSource=admin
MONGODB_RETRY_ATTEMPTS=3
MONGODB_RETRY_DELAY=5000
MONGODB_CONNECT_TIMEOUT=10000
MONGODB_TIMEOUT=30000

# Postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=123456
DATABASE_NAME=postgres
DATABASE_SCHEMA=public
DATABASE_SYNCHRONIZE=false        # Set to true only for local development
DATABASE_POOL_SIZE=10

# Kafka
KAFKA_DEFAULT_BROKER_URL=localhost:9094
KAFKA_DEFAULT_CLIENT_ID=service-template
KAFKA_DEFAULT_GROUP_ID=service-template
KAFKA_DEFAULT_AUTO_CREATE_TOPIC=true
KAFKA_DEFAULT_REQUEST_TIMEOUT=60000
KAFKA_DEFAULT_CONCURRENTLY=4
KAFKA_DEFAULT_SSL=false
KAFKA_DEFAULT_MECHANISM=NONE      # NONE | plain | scram-sha-256 | scram-sha-512
KAFKA_DEFAULT_USERNAME=dummy
KAFKA_DEFAULT_PASSWORD=dummy
