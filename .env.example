# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=  # REQUIRED — no default, must be set explicitly
POSTGRES_DB=jarvis

# Redis
REDIS_URL=redis://redis:6379/0

# Azure OpenAI (for future stories — not used in 1.1)
AZURE_OPENAI_ENDPOINT=https://tannt-m9jbr5vt-eastus2.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.2
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ai-memory repo path (server filesystem)
AI_MEMORY_REPO_PATH=/app/ai-memory

# Server
JARVIS_API_KEY=  # REQUIRED — no default, must be set explicitly
JARVIS_LOG_LEVEL=INFO

# MemU
MEMU_BASE_URL=http://memu-server:8010
