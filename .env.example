# Server
HOST=0.0.0.0
PORT=8000
NODE_ENV=local                    # local | development | staging | production | test | provision
RUNTIME_ENV=local                 # local | dev | test | stage | prod
TZ=UTC

# CORS (only applies in non-production environments)
CORS_ORIGINS=*                    # comma-separated origins or * for all

# Logger
LOG_LEVEL=info                    # trace | debug | info | warn | error | fatal
LOG_OUTPUT=text                   # text | json
LOG_FILE_PATH=                    # optional: path to log file
LOG_SYNC_FILE=/var/run/application.pid

# GRPC
GRPC_PORT=5000
GRPC_URL=0.0.0.0
MAX_SEND_SIZE_IN_MB=10
MAX_RECEIVE_SIZE_IN_MB=10

# Redis  (TODO [Story 13.16.5]: remove when RedisModule is deleted)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# MongoDB  (TODO [Story 13.16.5]: remove when MongoDBModule is deleted)
MONGODB_URI=mongodb://root:123456@localhost:27017/service-template-local-db?authSource=admin
MONGODB_RETRY_ATTEMPTS=3
MONGODB_RETRY_DELAY=5000
MONGODB_CONNECT_TIMEOUT=10000
MONGODB_TIMEOUT=30000

# Postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=123456
DATABASE_NAME=postgres
DATABASE_SCHEMA=public
DATABASE_SYNCHRONIZE=false        # Set to true only for local development
DATABASE_POOL_SIZE=10

# Kafka  (TODO [Story 13.16.5]: prune when domain-event Kafka path is removed)
KAFKA_DEFAULT_BROKER_URL=localhost:9094
KAFKA_DEFAULT_CLIENT_ID=service-template
KAFKA_DEFAULT_GROUP_ID=service-template
KAFKA_DEFAULT_AUTO_CREATE_TOPIC=true
KAFKA_DEFAULT_REQUEST_TIMEOUT=60000
KAFKA_DEFAULT_CONCURRENTLY=4
KAFKA_DEFAULT_SSL=false
KAFKA_DEFAULT_MECHANISM=NONE      # NONE | plain | scram-sha-256 | scram-sha-512
KAFKA_DEFAULT_USERNAME=dummy
KAFKA_DEFAULT_PASSWORD=dummy

# ─────────────────────────────────────────────────────────────────────────────
# Jarvis-specific (Story 13.1 — sourced from design/config-and-env.md §2)
# ─────────────────────────────────────────────────────────────────────────────

# Auth — plugin → server bearer token
API_KEY=<set in .env.local>

# Vault — local path + signed-url remote
VAULT_PATH=/var/lib/jarvis/ai-memory
VAULT_GIT_REMOTE=https://github.com/thuantan2060/ai-memory.git

# GitHub — PAT with repo scope on ai-memory
GH_TOKEN=<set in .env.local>

# Temporal (external homelab service)
TEMPORAL_ADDRESS=192.168.50.129:7233
TEMPORAL_NAMESPACE=jarvis
TEMPORAL_TASK_QUEUE=jarvis-dream

# Azure OpenAI
AZURE_OPENAI_API_KEY=<set in .env.local>
AZURE_OPENAI_API_INSTANCE_NAME=tannt-eastus2
AZURE_OPENAI_API_DEPLOYMENT_NAME=gpt-5-1
AZURE_OPENAI_API_VERSION=2025-05-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
LLM_MODEL=                         # optional logical alias; defaults to deployment name

# MemU
MEMU_API_URL=http://localhost:8080
MEMU_API_KEY=                      # empty in default homelab setup

# Phase budget overrides (defaults match design/config-and-env.md §2)
JARVIS_LIGHT_EXTRACTION_MAX_TOKENS=1500000
JARVIS_LIGHT_EXTRACTION_MAX_ITERATIONS=300
JARVIS_LIGHT_RECORD_MAX_TOKENS=1500000
JARVIS_LIGHT_RECORD_MAX_ITERATIONS=300
JARVIS_DEEP_PHASE1_MAX_TOKENS=1500000
JARVIS_DEEP_PHASE1_MAX_ITERATIONS=300
JARVIS_DEEP_PHASE2_MAX_TOKENS=1500000
JARVIS_DEEP_PHASE2_MAX_ITERATIONS=300
JARVIS_DEEP_PHASE3_MAX_TOKENS=2000000
JARVIS_DEEP_PHASE3_MAX_ITERATIONS=300
JARVIS_HEALTH_FIX_MAX_TOKENS=1500000
JARVIS_HEALTH_FIX_MAX_ITERATIONS=300
JARVIS_WEEKLY_REVIEW_MAX_TOKENS=1500000
JARVIS_WEEKLY_REVIEW_MAX_ITERATIONS=300
