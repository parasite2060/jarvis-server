# Server
HOST=0.0.0.0
PORT=3000
NODE_ENV=test
RUNTIME_ENV=test
TZ=UTC

# GRPC
GRPC_PORT=5000
GRPC_URL=0.0.0.0
MAX_SEND_SIZE_IN_MB=10
MAX_RECEIVE_SIZE_IN_MB=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=1

# MongoDB
MONGODB_URI=mongodb://root:123456@localhost:27017/service-template-test-db?authSource=admin
MONGODB_RETRY_ATTEMPTS=3
MONGODB_RETRY_DELAY=5000
MONGODB_CONNECT_TIMEOUT=10000
MONGODB_TIMEOUT=30000

# Postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=123456
DATABASE_NAME=postgres
DATABASE_SCHEMA=public
DATABASE_SYNCHRONIZE=false
DATABASE_POOL_SIZE=5

# Kafka
KAFKA_DEFAULT_BROKER_URL=localhost:9094
KAFKA_DEFAULT_CLIENT_ID=service-template-test
KAFKA_DEFAULT_GROUP_ID=service-template-test
KAFKA_DEFAULT_AUTO_CREATE_TOPIC=true
KAFKA_DEFAULT_REQUEST_TIMEOUT=60000
KAFKA_DEFAULT_CONCURRENTLY=4
KAFKA_DEFAULT_SSL=false
KAFKA_DEFAULT_MECHANISM=NONE
KAFKA_DEFAULT_USERNAME=dummy
KAFKA_DEFAULT_PASSWORD=dummy
