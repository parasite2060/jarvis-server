# Server
HOST=0.0.0.0
PORT=3000
NODE_ENV=test
RUNTIME_ENV=test
TZ=UTC

# Logger
LOG_LEVEL=debug
LOG_FILE=./logs/e2e-test.log
LOG_SYNC_FILE=./logs/application.pid

# Postgres (E2E port: 5433, Local: 5432)
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=test123
DATABASE_NAME=e2e_test_db
DATABASE_SCHEMA=public
DATABASE_SYNCHRONIZE=false
DATABASE_POOL_SIZE=5

# Redis (E2E port: 6380, Local: 6379)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASS=
REDIS_DB=1

# ─────────────────────────────────────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────────────────────────────────────
API_KEY=e2e-test-api-key

# ─────────────────────────────────────────────────────────────────────────────
# Vault — local filesystem for E2E (no git remote needed in local mode)
# ─────────────────────────────────────────────────────────────────────────────
VAULT_PATH=/tmp/jarvis-e2e-vault

# Storage mode: local (commit+merge only, no gh CLI, no push)
MEMORY_STORAGE_MODE=local

# ─────────────────────────────────────────────────────────────────────────────
# Temporal — docker-compose.e2e.yml runs temporalio/temporal on :7234
# ─────────────────────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7234
TEMPORAL_E2E_ADDRESS=localhost:7234
TEMPORAL_E2E_NAMESPACE=default
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=jarvis-dream

# ─────────────────────────────────────────────────────────────────────────────
# LLM — api-mock-server in docker-compose.e2e.yml on port 11435
# ─────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=llamacpp
LLAMACPP_BASE_URL=http://localhost:11435/v1
LLAMACPP_MODEL=gpt-4o-2024-11-20
LLAMACPP_API_KEY=not-needed

# Mock server control URL (used by ApiMockHelper in tests)
API_MOCK_URL=http://localhost:11435

# ─────────────────────────────────────────────────────────────────────────────
# MemU (docker-compose.e2e.yml service on port 8001)
# ─────────────────────────────────────────────────────────────────────────────
MEMU_API_URL=http://localhost:8001
MEMU_USER_ID=jarvis
MEMU_AGENT_ID=claude