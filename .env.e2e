# Server
HOST=0.0.0.0
PORT=3000
NODE_ENV=test
RUNTIME_ENV=test
TZ=UTC

# GRPC
GRPC_PORT=5000
GRPC_URL=0.0.0.0
MAX_SEND_SIZE_IN_MB=10
MAX_RECEIVE_SIZE_IN_MB=10

# Logger
LOG_LEVEL=debug
LOG_FILE=./logs/e2e-test.log
LOG_SYNC_FILE=./logs/application.pid

# Redis (E2E port: 6380, Local: 6379)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASS=
REDIS_DB=1

# MongoDB (E2E port: 27018, Local: 27017)
MONGODB_URI=mongodb://root:test123@localhost:27018/e2e_test_db?authSource=admin
MONGODB_RETRY_ATTEMPTS=3
MONGODB_RETRY_DELAY=1000
MONGODB_CONNECT_TIMEOUT=10000
MONGODB_TIMEOUT=30000

# Postgres (E2E port: 5433, Local: 5432)
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=test123
DATABASE_NAME=e2e_test_db
DATABASE_SCHEMA=public
DATABASE_SYNCHRONIZE=true
DATABASE_POOL_SIZE=5

# Kafka (E2E port: 9095, Local: 9094)
KAFKA_DEFAULT_BROKER_URL=localhost:9095
KAFKA_DEFAULT_CLIENT_ID=e2e-test-client
KAFKA_DEFAULT_GROUP_ID=e2e-test-group
KAFKA_DEFAULT_AUTO_CREATE_TOPIC=true
KAFKA_DEFAULT_REQUEST_TIMEOUT=30000
KAFKA_DEFAULT_CONCURRENTLY=1
KAFKA_DEFAULT_SSL=false
KAFKA_DEFAULT_MECHANISM=NONE      # NONE | plain | scram-sha-256 | scram-sha-512
KAFKA_DEFAULT_USERNAME=dummy
KAFKA_DEFAULT_PASSWORD=dummy

# ─────────────────────────────────────────────────────────────────────────────
# Jarvis-specific — non-secret fixtures for e2e (Story 13.1)
# ─────────────────────────────────────────────────────────────────────────────

# Auth
API_KEY=e2e-test-api-key

# Vault
VAULT_PATH=/tmp/jarvis-e2e-vault
VAULT_GIT_REMOTE=git@github.com:parasite2060/ai-memory-e2e.git

# GitHub — set GH_TOKEN in environment or CI secret; never commit the PAT here
GH_TOKEN=e2e-test-gh-token

# Temporal — docker-compose.e2e.yml runs temporalio/temporal on :7234 (local dev)
# For homelab Temporal cluster, set TEMPORAL_E2E_ADDRESS=192.168.50.129:7233 in env
TEMPORAL_ADDRESS=localhost:7234
TEMPORAL_E2E_ADDRESS=localhost:7234
TEMPORAL_E2E_NAMESPACE=default
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=jarvis-dream

# Azure OpenAI (e2e uses fixture values; no live calls in 13.1)
AZURE_OPENAI_API_KEY=e2e-test-azure-key
AZURE_OPENAI_API_INSTANCE_NAME=e2e-instance
AZURE_OPENAI_API_DEPLOYMENT_NAME=gpt-test
AZURE_OPENAI_API_VERSION=2025-05-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large

# MemU
MEMU_API_URL=http://192.168.50.214:8001
MEMU_USER_ID=jarvis
MEMU_AGENT_ID=claude

# LLM provider for Tier 2 live tests (JARVIS_E2E_LIVE_LLM=1)
LLM_PROVIDER=llamacpp
LLAMACPP_BASE_URL=http://0.0.0.0:8080/v1
LLAMACPP_MODEL=local
LLAMACPP_API_KEY=not-needed
