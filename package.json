{
  "name": "nestjs-bun-crud-template",
  "version": "1.0.0",
  "description": "NestJS + Bun CRUD template with Clean Architecture, CQRS, Domain Events (Kafka), PostgreSQL, MongoDB",
  "author": "TanNT",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:ci": "eslint-output \"{src,apps,libs,test}/**/*.ts\" --audit-level=high",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "dotenv -e .env.e2e -- jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e:watch": "dotenv -e .env.e2e -- jest --config ./test/jest-e2e.json --watch",
    "test:e2e:cov": "dotenv -e .env.e2e -- jest --config ./test/jest-e2e.json --coverage",
    "test:e2e:docker": "docker compose -f docker-compose.e2e.yml up -d --wait && (bun run test:e2e; EXIT=$?; docker compose -f docker-compose.e2e.yml down -v; exit $EXIT)",
    "e2e:infra:up": "docker compose -f docker-compose.e2e.yml up -d --wait",
    "e2e:infra:down": "docker compose -f docker-compose.e2e.yml down -v",
    "e2e:logs": "tail -f logs/e2e-test.log",
    "e2e:logs:clean": "rm -f logs/e2e-test*.log && rm -f logs/application.pid",
    "test:ci": "jest --coverage --runInBand --ci --reporters=default --reporters=jest-junit --reporters=github-actions --json --testLocationInResults --outputFile=report/coverage/jest.json --verbose",
    "migration:create": "bun tools/migration.ts create",
    "migration:generate": "bun tools/migration.ts generate",
    "migration:run": "bun tools/migration.ts run",
    "migration:revert": "bun tools/migration.ts revert",
    "prepare": "husky install",
    "proto:gen:sample": "node scripts/proto-gen.js sample"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.1",
    "@grpc/proto-loader": "^0.7.10",
    "@keyvhq/core": "^2.1.11",
    "@nestjs-redis/kit": "^0.13.1",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.0.12",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.12",
    "@nestjs/cqrs": "^11.0.2",
    "@nestjs/microservices": "^11.0.12",
    "@nestjs/mongoose": "^11.0.0",
    "@nestjs/platform-express": "^11.0.12",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@temporalio/activity": "~1.17.0",
    "@temporalio/client": "~1.17.0",
    "@temporalio/worker": "~1.17.0",
    "@temporalio/workflow": "~1.17.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.2.3",
    "joi": "^18.0.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^7.6.8",
    "nestjs-cls": "^5.0.0",
    "pg": "^8.11.3",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.1",
    "rimraf": "^3.0.2",
    "rxjs": "^7.2.0",
    "simple-git": "^3.36.0",
    "typeorm": "^0.3.17",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@golevelup/ts-jest": "^0.7.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.12",
    "@stylistic/eslint-plugin": "^5.2.0",
    "@stylistic/eslint-plugin-ts": "^4.2.0",
    "@temporalio/testing": "~1.17.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.6",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "dotenv-cli": "^7.3.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-output": "^4.0.2",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^15.0.2",
    "mongodb-memory-server": "^9.5.0",
    "pg-mem": "^3.0.5",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.0",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  },
  "jest-junit": {
    "outputDirectory": "./report/unit",
    "outputName": "test-report.xml"
  },
  "lint-staged": {
    "{src,apps,libs,test}/**/*.ts": [
      "bun run lint"
    ]
  }
}
