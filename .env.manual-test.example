# Manual Test Environment — Tier 2 Configuration
# Copy to .env.manual-test and fill in real values. NEVER commit this file.
#
# Usage:
#   cp .env.manual-test.example .env.manual-test
#   # Set the five JARVIS_MANUAL_* vars below (match your machine env)
#   docker compose -f docker-compose.manual-test.yml --env-file .env.manual-test up -d --wait

# ── Credentials (read from machine env or fill in directly) ──────────────────
# These five vars are the only ones you need to set.
JARVIS_MANUAL_GH_REPO=
JARVIS_MANUAL_GH_TOKEN=
JARVIS_MANUAL_OPENAI_URL=
JARVIS_MANUAL_OPENAI_TOKEN=
JARVIS_MANUAL_OPENAI_MODEL=

# ── Auth (API key for the Jarvis server itself) ───────────────────────────────
JARVIS_API_KEY=manual-test-api-key

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=manual-test-secret

# ── Optional overrides ────────────────────────────────────────────────────────
LOG_LEVEL=info
MEMU_USER_ID=jarvis
MEMU_AGENT_ID=claude
