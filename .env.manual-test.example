# Manual Test Environment — Tier 2 Configuration
# Copy to .env.manual-test and fill in real values. NEVER commit this file.
#
# Usage:
#   cp .env.manual-test.example .env.manual-test
#   # Edit .env.manual-test with your real credentials
#   docker compose -f docker-compose.manual-test.yml --env-file .env.manual-test up -d --wait

# ── Auth ──────────────────────────────────────────────────────────────────────
# API key the plugin (and manual test curl commands) use to authenticate
JARVIS_API_KEY=your-manual-test-api-key-here

# ── GitHub ────────────────────────────────────────────────────────────────────
# Fine-grained PAT with repo scope on the ai-memory repo
# Used by: vault-init (clone), jarvis-server (git ops, PR creation)
GH_TOKEN=ghp_your_personal_access_token_here

# The ai-memory repo (HTTPS URL preferred for Docker clone)
# Use your real personal vault repo, or a dedicated test fork
AI_MEMORY_REPO=the-repo-you-want-to-test-with-here

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=choose-a-strong-password

# ── LLM Provider — choose ONE block ──────────────────────────────────────────

# Option A: Local llama.cpp (default — points at host machine)
# Start llama.cpp server on host: ./server -m model.gguf --host 0.0.0.0 --port 8080
# LLM_PROVIDER=llamacpp
# LLM_BASE_URL=http://host.docker.internal:8080/v1
# LLM_MODEL=gemma-4-E4B-it-Q8_0
# LLM_API_KEY=not-needed
# LLM_EMBEDDING_MODEL=text-embedding-3-large

# Option B: Azure OpenAI (comment out Option A and uncomment this block)
#LLM_PROVIDER=azure
#AZURE_OPENAI_API_KEY=your_azure_api_key
#AZURE_OPENAI_API_INSTANCE_NAME=your_instance_name
#AZURE_OPENAI_API_DEPLOYMENT_NAME=gpt-5-1
#AZURE_OPENAI_API_VERSION=2025-05-01-preview
#AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
#LLM_EMBEDDING_MODEL=text-embedding-3-large

# Option C: OpenAI-compatible endpoint (e.g. OpenRouter, any OpenAI API)
LLM_PROVIDER=openai-compatible
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPATIBLE_MODEL=anthropic/claude-3-haiku
OPENAI_COMPATIBLE_API_KEY=sk-or-your-key-here

# ── Optional overrides ────────────────────────────────────────────────────────
LOG_LEVEL=info
MEMU_USER_ID=jarvis
MEMU_AGENT_ID=claude
