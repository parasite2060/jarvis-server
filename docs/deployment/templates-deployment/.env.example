# Jarvis Server — Production Environment Variables
# =================================================
# Copy to .env and fill in all REQUIRED values.
# Run: docker compose -f docker-compose.prod.yml up -d

# ── Database (external PostgreSQL 17 + pgvector) ──
DB_HOST=                              # REQUIRED — IP or hostname
DB_PORT=5432
DB_USER=jarvis
DB_PASSWORD=                          # REQUIRED
DB_NAME=jarvis

# ── Redis (external) ──
REDIS_URL=                            # REQUIRED — e.g. redis://:password@host:6379/0

# ── LLM (any OpenAI-compatible provider) ──
LLM_API_KEY=                          # REQUIRED — API key
LLM_ENDPOINT=                         # REQUIRED — e.g. https://api.openai.com/
LLM_MODEL=                            # REQUIRED — e.g. gpt-4o, gpt-5.4
LLM_BASE_URL=                         # REQUIRED — e.g. https://api.openai.com/v1/
LLM_EMBEDDING_BASE_URL=               # REQUIRED — same or separate endpoint
LLM_EMBEDDING_MODEL=text-embedding-3-large

# ── Jarvis Server ──
JARVIS_API_KEY=                       # REQUIRED — generate a strong random key
JARVIS_LOG_LEVEL=INFO
JARVIS_MEMORY_PATH=/app/ai-memory
JARVIS_GITHUB_PAT=                    # REQUIRED — fine-grained PAT (contents + pull_requests)

# ── MemU ──
MEMU_BASE_URL=http://memu-server:8000

# ── Port Mapping (optional) ──
# JARVIS_PORT=8000
# MEMU_UI_PORT=8011
# TEMPORAL_UI_PORT=8088
